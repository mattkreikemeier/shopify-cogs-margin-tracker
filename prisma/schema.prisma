generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ProductCost {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop            String
  productId       String
  variantId       String
  inventoryItemId String?
  productTitle    String
  variantTitle    String   @default("")
  sku             String   @default("")
  salePrice       Decimal  @db.Decimal(12, 2)
  cost            Decimal? @db.Decimal(12, 2)
  marginPct       Decimal? @db.Decimal(5, 2)
  currency        String   @default("USD")
  syncedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, variantId])
  @@index([shop])
  @@index([shop, marginPct])
}

model ShopSettings {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop                 String   @unique
  paymentFeeRate       Decimal  @default(2.9) @db.Decimal(5, 3)
  paymentFeeFlat       Decimal  @default(0.30) @db.Decimal(5, 2)
  marginAlertThreshold Decimal? @db.Decimal(5, 2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model OrderLineItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop           String
  orderId        String
  orderName      String
  orderDate      DateTime
  lineItemId     String
  productId      String?
  variantId      String?
  productTitle   String
  variantTitle   String   @default("")
  quantity       Int
  unitPrice      Decimal  @db.Decimal(12, 2)
  unitCost       Decimal? @db.Decimal(12, 2)
  revenue        Decimal  @db.Decimal(12, 2)
  grossProfit    Decimal? @db.Decimal(12, 2)
  marginPct      Decimal? @db.Decimal(5, 2)
  discountAmount Decimal? @db.Decimal(12, 2)
  discountCodes  String?
  currency       String   @default("USD")
  createdAt      DateTime @default(now())

  @@unique([shop, lineItemId])
  @@index([shop])
  @@index([shop, orderDate])
  @@index([shop, productId])
}

model Expense {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop             String
  name             String
  category         String   @default("Other")
  amount           Decimal  @db.Decimal(12, 2)
  frequency        String   @default("monthly")
  allocationMethod String   @default("proportional")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shop])
  @@index([shop, isActive])
}

model AiAnalysisCache {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop           String   @unique
  analysis       String   @db.Text
  period         String   @default("30d")
  completedItems String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shop])
}

model MarginSnapshot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop         String
  snapshotDate DateTime @db.Date
  totalRevenue Decimal  @db.Decimal(14, 2)
  totalCogs    Decimal  @db.Decimal(14, 2)
  grossProfit  Decimal  @db.Decimal(14, 2)
  avgMarginPct Decimal  @db.Decimal(5, 2)
  orderCount   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shop, snapshotDate])
  @@index([shop])
  @@index([shop, snapshotDate])
}
